{
  "realm": "a3s-realm",
  "enabled": true,
  "clients": [
    {
      "clientId": "a3s-test-client",
      "enabled": true,
      "publicClient": false,
      "secret": "a3s-test-secret",
      "attributes": {
        "access.token.header.type.rfc9068": "true"
      },
      "serviceAccountsEnabled": true,
      "protocolMappers": [
        {
          "name": "a3s-test-audience-1",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "a3s-test1",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "a3s-test-audience-2",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "a3s-test2",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ]
}
