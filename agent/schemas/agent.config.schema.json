{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "A3S Agent Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "llm": { "$ref": "#/$defs/LlmConfig" },
    "agent": { "$ref": "#/$defs/AgentConfig" },
    "server": {
      "$ref": "#/$defs/ServerConfig",
      "default": {
        "listen_address": "127.0.0.1",
        "listen_port": 8000
      }
    },
    "auth": {
      "anyOf": [
        { "$ref": "#/$defs/OAuthConfig" },
        { "$ref": "#/$defs/ApiKeyAuthConfig" },
        { "const": "none", "type": "string" }
      ],
      "title": "Auth"
    },
    "mcp_servers": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "format": "uri",
            "minLength": 1,
            "type": "string"
          },
          { "$ref": "#/$defs/EnvVarPlaceholder" }
        ]
      },
      "default": [],
      "title": "Mcp Servers"
    },
    "logging": {
      "$ref": "#/$defs/LoggingConfig",
      "default": {
        "level": "INFO",
        "format": "plain"
      }
    }
  },
  "required": ["llm", "agent", "auth"],
  "$defs": {
    "EnvVarPlaceholder": {
      "type": "string",
      "pattern": "^\\$\\{[^}]+\\}$"
    },
    "LlmConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "api_url": {
          "anyOf": [
            {
              "format": "uri",
              "minLength": 1,
              "title": "Api Url",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "api_key": {
          "anyOf": [
            {
              "format": "password",
              "minLength": 1,
              "title": "Api Key",
              "type": "string",
              "writeOnly": true
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "model": {
          "anyOf": [
            {
              "minLength": 1,
              "title": "Model",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        }
      },
      "required": ["api_url", "api_key", "model"],
      "title": "LlmConfig"
    },
    "AgentConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "anyOf": [
            {
              "minLength": 1,
              "title": "Name",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "description": {
          "anyOf": [
            {
              "minLength": 1,
              "title": "Description",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "instructions": {
          "anyOf": [
            {
              "minLength": 1,
              "title": "Instructions",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        }
      },
      "required": ["name", "description", "instructions"],
      "title": "AgentConfig"
    },
    "ServerConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "listen_address": {
          "anyOf": [
            {
              "format": "ipv4",
              "type": "string"
            },
            {
              "const": "localhost",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ],
          "default": "127.0.0.1",
          "title": "Listen Address"
        },
        "listen_port": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "default": 8000,
              "title": "Listen Port"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        }
      },
      "title": "ServerConfig"
    },
    "OAuthConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "anyOf": [
            {
              "const": "oauth2",
              "default": "oauth2",
              "title": "Mode",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "issuer_url": {
          "anyOf": [
            {
              "format": "uri",
              "minLength": 1,
              "title": "Issuer Url",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "policies": {
          "$ref": "#/$defs/OAuthPoliciesConfig"
        }
      },
      "required": ["issuer_url", "policies"],
      "title": "OAuthConfig"
    },
    "OAuthPoliciesConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "jwt": {
          "anyOf": [
            { "$ref": "#/$defs/OAuthJwtPoliciesConfig" },
            { "type": "null" }
          ],
          "default": null
        },
        "introspection": {
          "anyOf": [
            { "$ref": "#/$defs/OAuthDiscoveredIntrospectionPolicyConfig" },
            { "$ref": "#/$defs/OAuthStaticIntrospectionPolicyConfig" },
            { "type": "null" }
          ],
          "default": null,
          "title": "Introspection"
        }
      },
      "anyOf": [
        {
          "required": ["jwt"],
          "properties": {
            "jwt": { "not": { "type": "null" } }
          }
        },
        {
          "required": ["introspection"],
          "properties": {
            "introspection": {
              "not": { "type": "null" }
            }
          }
        }
      ],
      "title": "OAuthPoliciesConfig"
    },
    "OAuthJwtPoliciesConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "jwks": {
          "anyOf": [
            { "$ref": "#/$defs/OAuthDiscoveredJwksPolicyConfig" },
            { "$ref": "#/$defs/OAuthStaticJwksPolicyConfig" }
          ],
          "title": "Jwks"
        },
        "rfc9068": {
          "anyOf": [
            { "$ref": "#/$defs/OAuthRfc9068PolicyConfig" },
            { "type": "null" }
          ],
          "default": null
        },
        "claims": {
          "type": "object",
          "propertyNames": {
            "minLength": 1
          },
          "additionalProperties": {
            "anyOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              { "$ref": "#/$defs/EnvVarPlaceholder" }
            ]
          },
          "title": "Claims"
        }
      },
      "required": ["jwks"],
      "title": "OAuthJwtPoliciesConfig"
    },
    "OAuthDiscoveredIntrospectionPolicyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "discovered": {
          "anyOf": [
            {
              "const": true,
              "default": true,
              "title": "Discovered",
              "type": "boolean"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "client_id": {
          "anyOf": [
            {
              "minLength": 1,
              "title": "Client Id",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "client_secret": {
          "anyOf": [
            {
              "format": "password",
              "minLength": 1,
              "title": "Client Secret",
              "type": "string",
              "writeOnly": true
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "auth_method": {
          "anyOf": [
            {
              "type": "string",
              "enum": ["client_secret_basic", "client_secret_post"],
              "default": "client_secret_basic",
              "title": "Auth Method"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        }
      },
      "required": ["client_id", "client_secret"],
      "title": "OAuthDiscoveredIntrospectionPolicyConfig"
    },
    "OAuthDiscoveredJwksPolicyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "discovered": {
          "anyOf": [
            {
              "const": true,
              "default": true,
              "title": "Discovered",
              "type": "boolean"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        }
      },
      "title": "OAuthDiscoveredJwksPolicyConfig"
    },
    "OAuthStaticJwksPolicyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "discovered": {
          "anyOf": [
            {
              "const": false,
              "default": false,
              "title": "Discovered",
              "type": "boolean"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "url": {
          "anyOf": [
            {
              "format": "uri",
              "minLength": 1,
              "title": "Url",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        }
      },
      "required": ["url"],
      "title": "OAuthStaticJwksPolicyConfig"
    },
    "OAuthRfc9068PolicyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resource_server": {
          "anyOf": [
            {
              "minLength": 1,
              "title": "Resource Server",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        }
      },
      "required": ["resource_server"],
      "title": "OAuthRfc9068PolicyConfig"
    },
    "OAuthStaticIntrospectionPolicyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "discovered": {
          "anyOf": [
            {
              "const": false,
              "default": false,
              "title": "Discovered",
              "type": "boolean"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "endpoint": {
          "anyOf": [
            {
              "format": "uri",
              "minLength": 1,
              "title": "Endpoint",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "client_id": {
          "anyOf": [
            {
              "minLength": 1,
              "title": "Client Id",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "client_secret": {
          "anyOf": [
            {
              "format": "password",
              "minLength": 1,
              "title": "Client Secret",
              "type": "string",
              "writeOnly": true
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "auth_method": {
          "anyOf": [
            {
              "type": "string",
              "enum": ["client_secret_basic", "client_secret_post"],
              "default": "client_secret_basic",
              "title": "Auth Method"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        }
      },
      "required": ["endpoint", "client_id", "client_secret"],
      "title": "OAuthStaticIntrospectionPolicyConfig"
    },
    "ApiKeyAuthConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "anyOf": [
            {
              "const": "api_key",
              "default": "api_key",
              "title": "Mode",
              "type": "string"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "api_key": {
          "anyOf": [
            {
              "format": "password",
              "minLength": 1,
              "title": "Api Key",
              "type": "string",
              "writeOnly": true
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        }
      },
      "required": ["api_key"],
      "title": "ApiKeyAuthConfig"
    },
    "LoggingConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "anyOf": [
            {
              "type": "string",
              "enum": ["INFO", "DEBUG", "WARNING", "ERROR"],
              "default": "INFO",
              "title": "Level"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        },
        "format": {
          "anyOf": [
            {
              "type": "string",
              "enum": ["plain", "json"],
              "default": "plain",
              "title": "Format"
            },
            { "$ref": "#/$defs/EnvVarPlaceholder" }
          ]
        }
      },
      "title": "LoggingConfig"
    }
  }
}
