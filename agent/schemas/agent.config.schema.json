{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "EnvVarPlaceholder": {
      "type": "string",
      "pattern": "^\\$\\{[^}]+\\}$"
    },
    "AgentConfig": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "minLength": 1,
              "title": "Name",
              "type": "string"
            }
          ]
        },
        "description": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "minLength": 1,
              "title": "Description",
              "type": "string"
            }
          ]
        },
        "instructions": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "minLength": 1,
              "title": "Instructions",
              "type": "string"
            }
          ]
        },
        "subagents": {
          "additionalProperties": {
            "$ref": "#/$defs/SubagentConfig"
          },
          "propertyNames": {
            "minLength": 1
          },
          "title": "Subagents",
          "type": "object"
        },
        "skills_dir": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "default": "config/skills",
              "minLength": 1,
              "title": "Skills Dir",
              "type": "string"
            }
          ]
        }
      },
      "required": [
        "name",
        "description",
        "instructions"
      ],
      "title": "AgentConfig",
      "type": "object"
    },
    "ApiKeyAuthConfig": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "const": "api_key",
              "title": "Mode",
              "type": "string"
            }
          ]
        },
        "api_key": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "password",
              "minLength": 1,
              "title": "Api Key",
              "type": "string",
              "writeOnly": true
            }
          ]
        }
      },
      "required": [
        "mode",
        "api_key"
      ],
      "title": "ApiKeyAuthConfig",
      "type": "object"
    },
    "LlmConfig": {
      "additionalProperties": false,
      "properties": {
        "api_url": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "uri",
              "minLength": 1,
              "title": "Api Url",
              "type": "string"
            }
          ]
        },
        "api_key": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "password",
              "minLength": 1,
              "title": "Api Key",
              "type": "string",
              "writeOnly": true
            }
          ]
        },
        "model": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "minLength": 1,
              "title": "Model",
              "type": "string"
            }
          ]
        }
      },
      "required": [
        "api_url",
        "api_key",
        "model"
      ],
      "title": "LlmConfig",
      "type": "object"
    },
    "LoggingConfig": {
      "additionalProperties": false,
      "properties": {
        "level": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "default": "INFO",
              "enum": [
                "INFO",
                "DEBUG",
                "WARNING",
                "ERROR"
              ],
              "title": "Level",
              "type": "string"
            }
          ]
        },
        "format": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "default": "plain",
              "enum": [
                "plain",
                "json"
              ],
              "title": "Format",
              "type": "string"
            }
          ]
        }
      },
      "title": "LoggingConfig",
      "type": "object"
    },
    "McpServerConfig": {
      "additionalProperties": false,
      "properties": {
        "url": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "uri",
              "minLength": 1,
              "title": "Url",
              "type": "string"
            }
          ]
        },
        "auth": {
          "anyOf": [
            {
              "const": "none",
              "type": "string"
            },
            {
              "$ref": "#/$defs/OAuthTokenForwardAuthConfig"
            },
            {
              "$ref": "#/$defs/OAuthClientCredentialsAuthConfig"
            },
            {
              "$ref": "#/$defs/OAuthDiscoveredTokenExchangeAuthConfig"
            },
            {
              "$ref": "#/$defs/OAuthStaticTokenExchangeAuthConfig"
            }
          ],
          "title": "Auth"
        }
      },
      "required": [
        "url",
        "auth"
      ],
      "title": "McpServerConfig",
      "type": "object"
    },
    "OAuthClientCredentialsAuthConfig": {
      "additionalProperties": false,
      "properties": {
        "client_id": {
          "minLength": 1,
          "title": "Client Id",
          "type": "string"
        },
        "client_secret": {
          "format": "password",
          "minLength": 1,
          "title": "Client Secret",
          "type": "string",
          "writeOnly": true
        },
        "auth_method": {
          "default": "client_secret_basic",
          "enum": [
            "client_secret_basic",
            "client_secret_post"
          ],
          "title": "Auth Method",
          "type": "string"
        },
        "mode": {
          "const": "oauth_client_credentials",
          "title": "Mode",
          "type": "string"
        },
        "token_endpoint": {
          "format": "uri",
          "minLength": 1,
          "title": "Token Endpoint",
          "type": "string"
        }
      },
      "required": [
        "client_id",
        "client_secret",
        "mode",
        "token_endpoint"
      ],
      "title": "OAuthClientCredentialsAuthConfig",
      "type": "object"
    },
    "OAuthConfig": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "const": "oauth2",
              "title": "Mode",
              "type": "string"
            }
          ]
        },
        "issuer_url": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "uri",
              "minLength": 1,
              "title": "Issuer Url",
              "type": "string"
            }
          ]
        },
        "policies": {
          "$ref": "#/$defs/OAuthPoliciesConfig"
        }
      },
      "required": [
        "mode",
        "issuer_url",
        "policies"
      ],
      "title": "OAuthConfig",
      "type": "object"
    },
    "OAuthDiscoveredIntrospectionPolicyConfig": {
      "additionalProperties": false,
      "properties": {
        "client_id": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "minLength": 1,
              "title": "Client Id",
              "type": "string"
            }
          ]
        },
        "client_secret": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "password",
              "minLength": 1,
              "title": "Client Secret",
              "type": "string",
              "writeOnly": true
            }
          ]
        },
        "auth_method": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "default": "client_secret_basic",
              "enum": [
                "client_secret_basic",
                "client_secret_post"
              ],
              "title": "Auth Method",
              "type": "string"
            }
          ]
        },
        "discovered": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "const": true,
              "default": true,
              "title": "Discovered",
              "type": "boolean"
            }
          ]
        }
      },
      "required": [
        "client_id",
        "client_secret"
      ],
      "title": "OAuthDiscoveredIntrospectionPolicyConfig",
      "type": "object"
    },
    "OAuthDiscoveredJwksPolicyConfig": {
      "additionalProperties": false,
      "properties": {
        "discovered": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "const": true,
              "default": true,
              "title": "Discovered",
              "type": "boolean"
            }
          ]
        }
      },
      "title": "OAuthDiscoveredJwksPolicyConfig",
      "type": "object"
    },
    "OAuthDiscoveredTokenExchangeAuthConfig": {
      "additionalProperties": false,
      "properties": {
        "client_id": {
          "minLength": 1,
          "title": "Client Id",
          "type": "string"
        },
        "client_secret": {
          "format": "password",
          "minLength": 1,
          "title": "Client Secret",
          "type": "string",
          "writeOnly": true
        },
        "auth_method": {
          "default": "client_secret_basic",
          "enum": [
            "client_secret_basic",
            "client_secret_post"
          ],
          "title": "Auth Method",
          "type": "string"
        },
        "mode": {
          "const": "oauth_token_exchange",
          "title": "Mode",
          "type": "string"
        },
        "discovered": {
          "const": true,
          "default": true,
          "title": "Discovered",
          "type": "boolean"
        }
      },
      "required": [
        "client_id",
        "client_secret",
        "mode"
      ],
      "title": "OAuthDiscoveredTokenExchangeAuthConfig",
      "type": "object"
    },
    "OAuthJwtPolicyConfig": {
      "additionalProperties": false,
      "properties": {
        "jwks": {
          "anyOf": [
            {
              "$ref": "#/$defs/OAuthDiscoveredJwksPolicyConfig"
            },
            {
              "$ref": "#/$defs/OAuthStaticJwksPolicyConfig"
            }
          ],
          "title": "Jwks"
        },
        "rfc9068": {
          "anyOf": [
            {
              "$ref": "#/$defs/OAuthRfc9068PolicyConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "claims": {
          "additionalProperties": {
            "anyOf": [
              { "$ref": "#/$defs/EnvVarPlaceholder" },
              {
                  "minLength": 1,
                  "type": "string"
              }
            ]
          },
          "propertyNames": {
            "minLength": 1
          },
          "title": "Claims",
          "type": "object"
        }
      },
      "required": [
        "jwks"
      ],
      "title": "OAuthJwtPolicyConfig",
      "type": "object"
    },
    "OAuthPoliciesConfig": {
      "additionalProperties": false,
      "anyOf": [
        {
          "properties": {
            "jwt": {
              "not": {
                "type": "null"
              }
            }
          },
          "required": [
            "jwt"
          ]
        },
        {
          "properties": {
            "introspection": {
              "not": {
                "type": "null"
              }
            }
          },
          "required": [
            "introspection"
          ]
        }
      ],
      "properties": {
        "jwt": {
          "anyOf": [
            {
              "$ref": "#/$defs/OAuthJwtPolicyConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "introspection": {
          "anyOf": [
            {
              "$ref": "#/$defs/OAuthDiscoveredIntrospectionPolicyConfig"
            },
            {
              "$ref": "#/$defs/OAuthStaticIntrospectionPolicyConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Introspection"
        }
      },
      "title": "OAuthPoliciesConfig",
      "type": "object"
    },
    "OAuthRfc9068PolicyConfig": {
      "additionalProperties": false,
      "properties": {
        "resource_server": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "minLength": 1,
              "title": "Resource Server",
              "type": "string"
            }
          ]
        }
      },
      "required": [
        "resource_server"
      ],
      "title": "OAuthRfc9068PolicyConfig",
      "type": "object"
    },
    "OAuthStaticIntrospectionPolicyConfig": {
      "additionalProperties": false,
      "properties": {
        "client_id": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "minLength": 1,
              "title": "Client Id",
              "type": "string"
            }
          ]
        },
        "client_secret": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "password",
              "minLength": 1,
              "title": "Client Secret",
              "type": "string",
              "writeOnly": true
            }
          ]
        },
        "auth_method": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "default": "client_secret_basic",
              "enum": [
                "client_secret_basic",
                "client_secret_post"
              ],
              "title": "Auth Method",
              "type": "string"
            }
          ]
        },
        "discovered": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "const": false,
              "default": false,
              "title": "Discovered",
              "type": "boolean"
            }
          ]
        },
        "endpoint": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "uri",
              "minLength": 1,
              "title": "Endpoint",
              "type": "string"
            }
          ]
        }
      },
      "required": [
        "client_id",
        "client_secret",
        "endpoint"
      ],
      "title": "OAuthStaticIntrospectionPolicyConfig",
      "type": "object"
    },
    "OAuthStaticJwksPolicyConfig": {
      "additionalProperties": false,
      "properties": {
        "discovered": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "const": false,
              "default": false,
              "title": "Discovered",
              "type": "boolean"
            }
          ]
        },
        "url": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "uri",
              "minLength": 1,
              "title": "Url",
              "type": "string"
            }
          ]
        }
      },
      "required": [
        "url"
      ],
      "title": "OAuthStaticJwksPolicyConfig",
      "type": "object"
    },
    "OAuthStaticTokenExchangeAuthConfig": {
      "additionalProperties": false,
      "properties": {
        "client_id": {
          "minLength": 1,
          "title": "Client Id",
          "type": "string"
        },
        "client_secret": {
          "format": "password",
          "minLength": 1,
          "title": "Client Secret",
          "type": "string",
          "writeOnly": true
        },
        "auth_method": {
          "default": "client_secret_basic",
          "enum": [
            "client_secret_basic",
            "client_secret_post"
          ],
          "title": "Auth Method",
          "type": "string"
        },
        "mode": {
          "const": "oauth_token_exchange",
          "title": "Mode",
          "type": "string"
        },
        "discovered": {
          "const": false,
          "default": false,
          "title": "Discovered",
          "type": "boolean"
        },
        "token_endpoint": {
          "format": "uri",
          "minLength": 1,
          "title": "Token Endpoint",
          "type": "string"
        }
      },
      "required": [
        "client_id",
        "client_secret",
        "mode",
        "token_endpoint"
      ],
      "title": "OAuthStaticTokenExchangeAuthConfig",
      "type": "object"
    },
    "OAuthTokenForwardAuthConfig": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "const": "oauth_token_forward",
              "title": "Mode",
              "type": "string"
            }
          ]
        }
      },
      "required": [
        "mode"
      ],
      "title": "OAuthTokenForwardAuthConfig",
      "type": "object"
    },
    "OutboundApiKeyAuthConfig": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "const": "api_key",
              "title": "Mode",
              "type": "string"
            }
          ]
        },
        "api_key": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "password",
              "minLength": 1,
              "title": "Api Key",
              "type": "string",
              "writeOnly": true
            }
          ]
        }
      },
      "required": [
        "mode",
        "api_key"
      ],
      "title": "OutboundApiKeyAuthConfig",
      "type": "object"
    },
    "ServerConfig": {
      "additionalProperties": false,
      "properties": {
        "listen_address": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "ipv4",
              "type": "string"
            },
            {
              "const": "localhost",
              "type": "string"
            }
          ],
          "default": "127.0.0.1",
          "title": "Listen Address"
        },
        "listen_port": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "default": 8000,
              "maximum": 65535,
              "minimum": 1,
              "title": "Listen Port",
              "type": "integer"
            }
          ]
        }
      },
      "title": "ServerConfig",
      "type": "object"
    },
    "SubagentConfig": {
      "additionalProperties": false,
      "properties": {
        "url": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "format": "uri",
              "minLength": 1,
              "title": "Url",
              "type": "string"
            }
          ]
        },
        "type": {
          "anyOf": [
            { "$ref": "#/$defs/EnvVarPlaceholder" },
            {
              "enum": [
                "delegate",
                "peer"
              ],
              "title": "Type",
              "type": "string"
            }
          ]
        },
        "auth": {
          "anyOf": [
            {
              "const": "none",
              "type": "string"
            },
            {
              "$ref": "#/$defs/OAuthTokenForwardAuthConfig"
            },
            {
              "$ref": "#/$defs/OAuthClientCredentialsAuthConfig"
            },
            {
              "$ref": "#/$defs/OAuthDiscoveredTokenExchangeAuthConfig"
            },
            {
              "$ref": "#/$defs/OAuthStaticTokenExchangeAuthConfig"
            },
            {
              "$ref": "#/$defs/OutboundApiKeyAuthConfig"
            }
          ],
          "title": "Auth"
        }
      },
      "required": [
        "url",
        "type",
        "auth"
      ],
      "title": "SubagentConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "llm": {
      "$ref": "#/$defs/LlmConfig"
    },
    "agent": {
      "$ref": "#/$defs/AgentConfig"
    },
    "server": {
      "$ref": "#/$defs/ServerConfig",
      "default": {
        "listen_address": "127.0.0.1",
        "listen_port": 8000
      }
    },
    "auth": {
      "anyOf": [
        {
          "$ref": "#/$defs/OAuthConfig"
        },
        {
          "$ref": "#/$defs/ApiKeyAuthConfig"
        },
        {
          "const": "none",
          "type": "string"
        }
      ],
      "title": "Auth"
    },
    "mcp_servers": {
      "default": [],
      "items": {
        "$ref": "#/$defs/McpServerConfig"
      },
      "title": "Mcp Servers",
      "type": "array"
    },
    "logging": {
      "$ref": "#/$defs/LoggingConfig",
      "default": {
        "level": "INFO",
        "format": "plain"
      }
    }
  },
  "required": [
    "llm",
    "agent",
    "auth"
  ],
  "title": "A3S Agent Config",
  "type": "object"
}
